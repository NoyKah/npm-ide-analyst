# Normalize line endings. Store text as LF in the repo; check out per-platform
# unless overridden below.
* text=auto

# Files that run on Linux (shell scripts, the Node harness, Docker) MUST be LF
# on every platform, or they break when built/run in a Linux container or on a
# Linux host — even when checked out on Windows with core.autocrlf=true.
*.sh        text eol=lf
*.js        text eol=lf
*.j2        text eol=lf
Dockerfile  text eol=lf
*.py        text eol=lf

# PowerShell is Windows-side; CRLF is fine (and expected by some tooling).
*.ps1       text eol=crlf

# Treat known binaries as binary (no EOL munging).
*.png binary
*.jpg binary
*.tgz binary
*.vsix binary
