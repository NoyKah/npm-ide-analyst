<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>npm-ide-analyst report: {{ r.sample.name }}</title>
<style>
  :root {
    --paper:#e6e8eb; --card:#ffffff; --ink:#171b21; --muted:#5f6975;
    --line:#d3d8dd; --line2:#e4e7ea; --steel:#34556f;
    --high:#bd3a19; --med:#a1741d; --low:#6a7581;
    --sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    --mono: ui-monospace, "SF Mono", "Cascadia Code", Consolas, Menlo, monospace;
  }
  * { box-sizing: border-box; }
  body { background: var(--paper); color: var(--ink); font-family: var(--sans);
    line-height: 1.5; -webkit-font-smoothing: antialiased;
    margin: 0; padding: clamp(1rem, 3vw, 2.5rem); }
  .wrap { max-width: 940px; margin: 0 auto; }
  .tnum { font-variant-numeric: tabular-nums; }
  .mono { font-family: var(--mono); }

  /* masthead: band colour is chosen by the verdict */
  .mast { border-radius:10px; padding:1.4rem 1.5rem 1.5rem; position:relative;
    overflow:hidden; color:#f2e6e4; background:#33414f; }
  .mast.v-malicious { background:#8c160b; box-shadow:0 1px 0 #6d1109 inset; }
  .mast.v-suspicious { background:#985c14; box-shadow:0 1px 0 #764711 inset; color:#f7ecdd; }
  .mast.v-low-risk { background:#33414f; color:#e7ecf1; }
  .mast.v-clean { background:#1f5136; color:#e4f0e9; }
  .mast::after { content:""; position:absolute; inset:0; pointer-events:none;
    background: repeating-linear-gradient(135deg, rgba(255,255,255,.03) 0 2px, transparent 2px 9px); }
  .eyebrow { font-family:var(--mono); font-size:.7rem; letter-spacing:.22em;
    text-transform:uppercase; font-weight:600; opacity:.9; }
  .verdict { font-family:var(--mono); font-weight:700; letter-spacing:.02em;
    font-size:clamp(2rem,6vw,2.9rem); line-height:1; margin:.5rem 0 .1rem;
    text-transform:uppercase; display:flex; align-items:center; gap:.6rem; text-wrap:balance; }
  .verdict .dot { width:.7rem; height:.7rem; border-radius:50%; background:currentColor;
    opacity:.85; box-shadow:0 0 0 4px rgba(255,255,255,.15); animation:pulse 2.4s ease-in-out infinite; }
  @keyframes pulse { 50% { opacity:.35; } }
  @media (prefers-reduced-motion: reduce) { .verdict .dot { animation:none; } }
  .mast .sub { font-size:.92rem; max-width:60ch; margin-top:.3rem; opacity:.92; }
  .idline { margin-top:1rem; display:flex; flex-wrap:wrap; gap:.4rem .9rem;
    font-family:var(--mono); font-size:.82rem; opacity:.95; }
  .idline b { font-weight:700; }

  .stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(115px,1fr));
    gap:1px; background:var(--line); border:1px solid var(--line);
    border-radius:10px; overflow:hidden; margin:.9rem 0 1.4rem; }
  .stat { background:var(--card); padding:.85rem 1rem; }
  .stat .n { font-family:var(--mono); font-size:1.5rem; font-weight:700; line-height:1;
    letter-spacing:-.01em; }
  .stat .n.bad { color:#8f1a10; }
  .stat .l { font-size:.71rem; color:var(--muted); margin-top:.35rem;
    text-transform:uppercase; letter-spacing:.07em; }

  section { margin:1.8rem 0; }
  .shead { display:flex; align-items:baseline; gap:.8rem; margin-bottom:.9rem; }
  .shead h2 { font-size:1.02rem; margin:0; font-weight:650; letter-spacing:-.01em; }
  .shead .rule { flex:1; height:1px; background:var(--line); }
  .shead .count { font-family:var(--mono); font-size:.76rem; color:var(--muted); }

  .flist { display:grid; gap:1px; background:var(--line); border:1px solid var(--line);
    border-radius:8px; overflow:hidden; }
  .frow { display:grid; grid-template-columns:5rem 1fr; gap:.9rem;
    background:var(--card); padding:.7rem .9rem .7rem .75rem; border-left:4px solid var(--low); }
  .frow.s-high, .frow.s-critical { border-left-color:var(--high); }
  .frow.s-medium { border-left-color:var(--med); }
  .frow.s-low, .frow.s-info { border-left-color:var(--low); }
  .pill { font-family:var(--mono); font-size:.64rem; font-weight:700; letter-spacing:.05em;
    padding:.16rem 0; text-align:center; border-radius:4px; text-transform:uppercase; display:block; }
  .pill.s-high, .pill.s-critical { background:#f7e6e0; color:var(--high); }
  .pill.s-medium { background:#f6ecd8; color:var(--med); }
  .pill.s-low, .pill.s-info { background:#eceef0; color:var(--low); }
  .fcat { font-family:var(--mono); font-size:.64rem; color:var(--muted); margin-top:.35rem; text-align:center; word-break:break-all; }
  .ftitle { font-size:.9rem; font-weight:550; }
  .floc { font-family:var(--mono); font-size:.73rem; color:var(--steel); margin-left:.5rem; }
  .fev { font-family:var(--mono); font-size:.77rem; color:#333b44; background:#f5f6f7;
    border:1px solid var(--line2); border-radius:5px; padding:.3rem .5rem; margin-top:.4rem;
    overflow-x:auto; white-space:nowrap; }
  .empty { color:var(--muted); font-size:.88rem; font-style:italic; }

  .tl { position:relative; margin-left:.4rem; }
  .tl::before { content:""; position:absolute; left:4.55rem; top:.4rem; bottom:.4rem; width:2px; background:var(--line); }
  .ev { display:grid; grid-template-columns:3.6rem 1.1rem 1fr; gap:.7rem; align-items:start; padding:.28rem 0; }
  .ev .t { font-family:var(--mono); font-size:.76rem; color:var(--muted); text-align:right; padding-top:.05rem; }
  .ev .node { width:.7rem; height:.7rem; border-radius:50%; background:#c6ccd2;
    border:2px solid var(--paper); margin:.15rem auto 0; z-index:1; }
  .ev .k { font-family:var(--mono); font-size:.66rem; padding:.05rem .38rem; border-radius:3px;
    background:#eef0f2; color:var(--muted); margin-right:.5rem; letter-spacing:.03em; }
  .ev .txt { font-family:var(--mono); font-size:.8rem; color:#2b323b; word-break:break-word; }
  .ev.hot .node{ background:#8f1a10; } .ev.hot .k{ background:#f4ded9; color:#8f1a10; }
  .ev.hot .txt{ color:#8f1a10; font-weight:600; }
  .ev.warn .node{ background:var(--med); } .ev.warn .k{ background:#f4ecd7; color:#8a621a; }
  .ev.mark .node{ background:var(--steel); } .ev.mark .txt{ color:var(--steel); font-weight:600; }

  footer { margin-top:2rem; border-top:1px solid var(--line); padding-top:1.1rem;
    font-size:.8rem; color:var(--muted); }
  .hashes { display:grid; gap:.3rem; font-family:var(--mono); font-size:.72rem;
    word-break:break-all; margin:.5rem 0 1rem; }
  .hashes span { color:var(--steel); }
  .note { background:#eef1f3; border:1px solid var(--line); border-radius:7px;
    padding:.7rem .85rem; font-size:.78rem; color:#414a54; }
</style>
</head>
<body>
<div class="wrap">

  <div class="mast v-{{ r.verdict }}">
    <div class="eyebrow">npm-ide-analyst · DFIR analysis report</div>
    <div class="verdict"><span class="dot"></span>{{ r.verdict }}</div>
    <div class="sub">Automated static and dynamic analysis of an {{ r.sample.artifact_type }} artifact.</div>
    <div class="idline">
      <span><b>{{ r.sample.name }}</b>{% if r.sample.version %} @ {{ r.sample.version }}{% endif %}</span>
      <span>type: <b>{{ r.sample.artifact_type }}</b></span>
      <span>risk score: <b class="tnum">{{ r.score }}</b></span>
      {% if r.generated_at %}<span>analyzed: <b>{{ r.generated_at }}</b></span>{% endif %}
    </div>
  </div>

  <div class="stats">
    <div class="stat"><div class="n bad tnum">{{ r.score }}</div><div class="l">Risk score</div></div>
    <div class="stat"><div class="n tnum">{{ r.findings | length }}</div><div class="l">Findings</div></div>
    <div class="stat"><div class="n tnum">{{ high_count }}</div><div class="l">High severity</div></div>
    <div class="stat"><div class="n tnum">{{ static | length }} / {{ dynamic | length }}</div><div class="l">Static / dynamic</div></div>
    <div class="stat"><div class="n tnum">{{ categories | length }}</div><div class="l">Categories</div></div>
    <div class="stat"><div class="n tnum">{{ r.behavior | length }}</div><div class="l">Detonation events</div></div>
  </div>

  <section>
    <div class="shead"><h2>Static indicators</h2><span class="rule"></span><span class="count">read without executing</span></div>
    {% if static %}
    <div class="flist">
      {% for f in static %}
      <div class="frow s-{{ f.severity }}">
        <div><span class="pill s-{{ f.severity }}">{{ f.severity }}</span><div class="fcat">{{ f.category }}</div></div>
        <div>
          <span class="ftitle">{{ f.title }}</span>{% if f.location %}<span class="floc">{{ f.location }}</span>{% endif %}
          {% if f.evidence %}<div class="fev">{{ f.evidence }}</div>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}<p class="empty">No static indicators flagged.</p>{% endif %}
  </section>

  {% if r.behavior %}
  <section>
    <div class="shead"><h2>Dynamic Behavior</h2><span class="rule"></span><span class="count">observed during detonation</span></div>
    <div class="tl">
      {% for b in r.behavior %}
      {% set hot = b.kind in ['secret', 'network'] %}
      {% set warn = b.kind in ['process', 'eval', 'decode', 'dns'] %}
      <div class="ev{% if hot %} hot{% elif warn %} warn{% elif b.kind == 'detonation' %} mark{% endif %}">
        <div class="t tnum">{% if b.ts is not none %}{{ "%.1f"|format(b.ts) }}ms{% else %}-{% endif %}</div>
        <div class="node"></div>
        <div><span class="k">{{ b.kind }}</span><span class="txt">{{ b.detail }}</span></div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <footer>
    <div class="eyebrow">Sample integrity</div>
    <div class="hashes">
      {% if r.sample.sha256 %}<div><span>sha256</span> {{ r.sample.sha256 }}</div>{% endif %}
      {% if r.sample.sha512 %}<div><span>sha512</span> {{ r.sample.sha512 }}</div>{% endif %}
    </div>
    <div class="note"><b>Methodology.</b> Static findings are read from the sample as data;
      no sample code is executed on the host. Dynamic behavior, when present, was captured by
      detonating the sample inside a network-isolated container under an instrumented harness
      that logs and neuters every dangerous call.</div>
  </footer>

</div>
</body>
</html>
